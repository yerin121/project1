<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>우리 반 알콩달콩 공간</title>
    <style>
        /* 기본 스타일 리셋 및 배경 */
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Malgun Gothic', sans-serif;
        }
        body {
            background-color: #f0f4f8;
            color: #333;
            padding: 20px;
        }
        header {
            text-align: center;
            padding: 30px 0;
            background: linear-gradient(135deg, #a1c4fd 0%, #c2e9fb 100%);
            color: #fff;
            border-radius: 15px;
            margin-bottom: 30px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }
        header h1 {
            font-size: 2.5rem;
            text-shadow: 1px 1px 3px rgba(0,0,0,0.2);
        }
        .container {
            max-width: 800px;
            margin: 0 auto;
        }

        /* 글쓰기 및 사진 업로드 양식 */
        .form-section {
            background: #fff;
            padding: 25px;
            border-radius: 15px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
            margin-bottom: 30px;
        }
        .form-group {
            margin-bottom: 15px;
        }
        .form-group label {
            display: block;
            margin-bottom: 8px;
            font-weight: bold;
            color: #555;
        }
        .form-group input[type="text"], 
        .form-group textarea {
            width: 100%;
            padding: 12px;
            border: 1px solid #ddd;
            border-radius: 8px;
            font-size: 1rem;
            outline: none;
            transition: border 0.3s;
        }
        .form-group input[type="text"]:focus, 
        .form-group textarea:focus {
            border-color: #a1c4fd;
        }
        .form-group textarea {
            height: 120px;
            resize: none;
        }
        .form-group input[type="file"] {
            display: block;
            margin-top: 5px;
        }
        .submit-btn {
            width: 100%;
            padding: 12px;
            background-color: #4a90e2;
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 1.1rem;
            cursor: pointer;
            font-weight: bold;
            transition: background 0.2s;
        }
        .submit-btn:hover {
            background-color: #357abd;
        }

        /* 게시글 목록 구역 */
        .feed-section h2 {
            margin-bottom: 20px;
            color: #444;
            border-left: 5px solid #4a90e2;
            padding-left: 10px;
        }
        .post-card {
            background: white;
            padding: 20px;
            border-radius: 15px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.05);
            margin-bottom: 20px;
            animation: fadeIn 0.5s ease;
        }
        .post-header {
            display: flex;
            justify-content: space-between;
            color: #888;
            font-size: 0.9rem;
            margin-bottom: 15px;
            border-bottom: 1px solid #eee;
            padding-bottom: 8px;
        }
        .post-author {
            font-weight: bold;
            color: #4a90e2;
        }
        .post-content {
            font-size: 1.05rem;
            line-height: 1.6;
            white-space: pre-wrap; /* 줄바꿈 유지 */
            margin-bottom: 15px;
        }
        .post-image {
            max-width: 100%;
            max-height: 400px;
            display: block;
            border-radius: 8px;
            margin-top: 10px;
            object-fit: cover;
        }

        /* 애니메이션 효과 */
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>
</head>
<body>

    <div class="container">
        <!-- 헤더 영역 -->
        <header>
            <h1>우리 반 이야기 방 🏫</h1>
            <p>오늘 있었던 일, 나누고 싶은 사진을 공유해봐요!</p>
        </header>

        <!-- 게시글 작성 양식 -->
        <section class="form-section">
            <div class="form-group">
                <label for="author">작성자 (이름/번호)</label>
                <input type="text" id="author" placeholder="예: 1번 김태형">
            </div>
            <div class="form-group">
                <label for="content">이야기 나누기</label>
                <textarea id="content" placeholder="오늘 어떤 일이 있었나요?"></textarea>
            </div>
            <div class="form-group">
                <label for="image">추억 사진 첨부</label>
                <input type="file" id="image" accept="image/*">
            </div>
            <button class="submit-btn" onclick="addPost()">등록하기</button>
        </section>

        <!-- 게시글 피드 영역 -->
        <section class="feed-section">
            <h2>우리들의 기록</h2>
            <div id="post-feed">
                <!-- 작성된 글들이 여기에 동적으로 추가됩니다 -->
            </div>
        </section>
    </div>

    <!-- 자바스크립트 기능 구현 -->
    <script>
        function addPost() {
            const authorInput = document.getElementById('author');
            const contentInput = document.getElementById('content');
            const imageInput = document.getElementById('image');
            const postFeed = document.getElementById('post-feed');

            // 유효성 검사 (이름과 내용이 비어있는지 확인)
            if (authorInput.value.trim() === "" || contentInput.value.trim() === "") {
                alert("이름과 내용을 모두 입력해주세요!");
                return;
            }

            // 날짜 생성
            const now = new Date();
            const dateString = `${now.getFullYear()}-${now.getMonth()+1}-${now.getDate()} ${now.getHours()}:${now.getMinutes()}`;

            // 새 게시글 카드 생성
            const postCard = document.createElement('div');
            postCard.className = 'post-card';

            // 카드 상단 (작성자, 날짜)
            const postHeader = document.createElement('div');
            postHeader.className = 'post-header';
            postHeader.innerHTML = `<span class="post-author">✍️ ${authorInput.value}</span> <span>${dateString}</span>`;
            postCard.appendChild(postHeader);

            // 카드 본문 (텍스트)
            const postContent = document.createElement('div');
            postContent.className = 'post-content';
            postContent.textContent = contentInput.value;
            postCard.appendChild(postContent);

            // 이미지 처리 (파일이 첨부되었을 경우)
            if (imageInput.files && imageInput.files[0]) {
                const reader = new FileReader();
                
                // 이미지를 읽어와서 카드가 완성되면 피드에 추가
                reader.onload = function(e) {
                    const postImg = document.createElement('img');
                    postImg.className = 'post-image';
                    postImg.src = e.target.result;
                    postCard.appendChild(postImg);
                    
                    // 피드 최상단에 추가 (새 글이 위로 오게)
                    postFeed.insertBefore(postCard, postFeed.firstChild);
                }
                reader.readAsDataURL(imageInput.files[0]);
            } else {
                // 이미지가 없을 때는 바로 피드 최상단에 추가
                postFeed.insertBefore(postCard, postFeed.firstChild);
            }

            // 입력창 초기화
            authorInput.value = "";
            contentInput.value = "";
            imageInput.value = "";
        }
    </script>
</body>
</html>
